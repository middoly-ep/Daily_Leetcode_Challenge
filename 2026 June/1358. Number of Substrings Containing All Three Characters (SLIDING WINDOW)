#include <string>
#include <map>

using namespace std;

class Solution {
public:
    int numberOfSubstrings(string s) {
        int l = 0;
        int r = 0;
        unordered_map<char, int> freq;
        freq[s[l]] = 1;
        int cnt = 0;
        while (true){
            if (freq['a'] > 0 && freq['b'] > 0 && freq['c'] > 0){
                cnt += s.size() - r;
                freq[s[l]]--;
                l++;
            }
            else{
                r++;
                if (r >= s.size()) return cnt;
                freq[s[r]]++;
            }
        }
        return cnt;
    }
};
